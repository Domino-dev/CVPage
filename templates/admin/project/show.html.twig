{% extends 'admin/base.html.twig' %}

{% block body %}

<section class="article-sizing">
    <div class="article">
        <div class="article-content">
            <div class="image-box">
                 <img src="{{ asset('images/projects/' ~ project.mImage) }}" alt="{{ project.name }}">
            </div>
            <div class="tags">
                <p class='tag'>{{ project.type.value }}</p>
            </div>
            <div class='article-body'>
                <h1>{{project.name}}</h1>
                <div class='article-content-short-description'>
                    {{project.shortDescription}}
                </div>
                <div class='article-content-long-description'>
                    {{project.longDescription |raw}}
                </div>
            </div>
        </div>
    </div>
    <a href={{path('app_admin_project_edit', {'slug': project.slug}) }}>Edit</a>
    <form method="POST" action="{{ path('app_admin_project_delete', {'slug': project.slug}) }}" style="display:inline;" onsubmit="return confirm('Do you want to delete this project?');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ project.slug) }}">
        <button class="btn btn-danger btn-sm">Delete</button>
    </form>
</section>
{% endblock %}